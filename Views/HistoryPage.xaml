<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Woo_.Views.HistoryPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Woo_.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:PathToBitmapImageConverter x:Key="PathToBitmap" />
        <converters:LogSeverityBrushConverter x:Key="LogSeverityBrush" />
    </Page.Resources>

    <Grid Padding="24,20" ColumnSpacing="18" RowSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="2" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <AutoSuggestBox
                PlaceholderText="Search by app name or website URL"
                QueryIcon="Find"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="1">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71C;" FontSize="12" />
                    <TextBlock Text="Filter" />
                </StackPanel>
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <StackPanel Width="230" Spacing="10">
                            <ComboBox Header="Framework" SelectedIndex="{Binding FrameworkFilterIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="All frameworks" />
                                <ComboBoxItem Content="Electron" />
                                <ComboBoxItem Content="Tauri" />
                            </ComboBox>
                            <ComboBox Header="Status" SelectedIndex="{Binding StatusFilterIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="All statuses" />
                                <ComboBoxItem Content="Success" />
                                <ComboBoxItem Content="Failed" />
                            </ComboBox>
                            <ComboBox Header="Sort" SelectedIndex="{Binding SortIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Newest first" />
                                <ComboBoxItem Content="Oldest first" />
                                <ComboBoxItem Content="App name" />
                                <ComboBoxItem Content="Framework" />
                                <ComboBoxItem Content="Status" />
                            </ComboBox>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button
                Grid.Column="2"
                Click="ExportCsv_Click"
                Visibility="{Binding HasAnyRecords, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xEDE1;" FontSize="12" />
                    <TextBlock Text="Export CSV" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="3"
                Click="ClearAll_Click"
                Visibility="{Binding HasAnyRecords, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74D;" FontSize="12" />
                    <TextBlock Text="Clear All History" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding HasRecords, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                <FontIcon Glyph="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="No exports found" Style="{ThemeResource SubtitleTextBlockStyle}" />
            </StackPanel>

            <ListView
                ItemsSource="{Binding FilteredRecords}"
                SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                SelectionMode="Single"
                Visibility="{Binding HasRecords, Converter={StaticResource BoolToVisibility}}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12" ColumnSpacing="12">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Open folder" Tag="{Binding}" Click="OpenFolder_Click" />
                                    <MenuFlyoutItem Text="Copy URL" Tag="{Binding}" Click="CopyUrl_Click" />
                                    <MenuFlyoutItem Text="Re-build" Tag="{Binding}" Click="Rebuild_Click" />
                                    <MenuFlyoutItem Text="Export App Settings" Tag="{Binding}" Click="ExportPreset_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Delete" Tag="{Binding}" Click="DeleteRecord_Click" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="38" Height="38" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Image Source="{Binding IconPath, Converter={StaticResource PathToBitmap}}" Stretch="Uniform" Margin="6" />
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Binding AppName}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                                <HyperlinkButton Padding="0" Content="{Binding Url}" Tag="{Binding Url}" Click="OpenUrl_Click" />
                                <TextBlock Text="{Binding OutputPath}" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Border Padding="10,4" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock Text="{Binding Status}" />
                                </Border>
                                <TextBlock Text="{Binding Framework}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                                <TextBlock Text="{Binding BuildDurationText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Width="520"
            Padding="18"
            CornerRadius="8"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            Visibility="{Binding HasSelectedRecord, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer>
                <StackPanel Spacing="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Export details" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <Border Width="76" Height="76" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Image Margin="8" Source="{Binding SelectedRecord.IconPath, Converter={StaticResource PathToBitmap}}" Stretch="Uniform" />
                            </Border>
                            <StackPanel Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedRecord.AppName}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedRecord.CreatedAt}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedRecord.BuildDurationText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="Paths" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Website URL" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <HyperlinkButton Padding="0" Content="{Binding SelectedRecord.Url}" Tag="{Binding SelectedRecord.Url}" Click="OpenUrl_Click" />
                        <TextBlock Text="Output folder" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <HyperlinkButton Padding="0" Content="{Binding SelectedRecord.OutputPath}" Tag="{Binding SelectedRecord.OutputPath}" Click="OpenLocalPath_Click" />
                        <StackPanel
                            Spacing="8"
                            Visibility="{Binding SelectedRecord.HasIconUrl, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Icon URL" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <HyperlinkButton Padding="0" Content="{Binding SelectedRecord.IconUrl}" Tag="{Binding SelectedRecord.IconUrl}" Click="OpenUrl_Click" />
                        </StackPanel>
                        <TextBlock Text="Local icon path" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <HyperlinkButton Padding="0" Content="{Binding SelectedRecord.IconPath}" Tag="{Binding SelectedRecord.IconPath}" Click="OpenLocalPath_Click" />
                    </StackPanel>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                    <Grid RowSpacing="8" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Framework" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="{Binding SelectedRecord.Framework}" />
                        <TextBlock Grid.Row="1" Text="Status" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRecord.Status}" />
                        <TextBlock Grid.Row="2" Text="Window" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1">
                            <Run Text="{Binding SelectedRecord.WindowWidth}" />
                            <Run Text=" x " />
                            <Run Text="{Binding SelectedRecord.WindowHeight}" />
                        </TextBlock>
                        <TextBlock Grid.Row="3" Text="Ad blocker" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedRecord.AdBlockerEnabled}" />
                        <TextBlock Grid.Row="4" Text="Single exe" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedRecord.SingleExe}" />
                        <TextBlock Grid.Row="5" Text="New link redirect" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedRecord.NewLinkRedirect}" />
                        <TextBlock Grid.Row="6" Text="Duration" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedRecord.BuildDurationText}" />
                        <TextBlock Grid.Row="7" Text="Allow downloading" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedRecord.AllowDownloads}" />
                    </Grid>

                    <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                        <AppBarButton Label="Open" Command="{Binding OpenFolderCommand}" CommandParameter="{Binding SelectedRecord}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Label="Re-build" Command="{Binding RebuildCommand}" CommandParameter="{Binding SelectedRecord}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Label="Copy URL" Command="{Binding CopyUrlCommand}" CommandParameter="{Binding SelectedRecord}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton Label="Delete" Command="{Binding DeleteRecordCommand}" CommandParameter="{Binding SelectedRecord}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE74D;" FontSize="12" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>

                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="8" Visibility="{Binding SelectedRecord.HasCustomScriptCode, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Custom script" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Border
                            MaxHeight="220"
                            Padding="10"
                            CornerRadius="8"
                            Background="#101216"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <ScrollViewer>
                                <RichTextBlock
                                    x:Name="CustomScriptPreview"
                                    FontFamily="{StaticResource MonospaceFont}"
                                    TextWrapping="Wrap"
                                    IsTextSelectionEnabled="True"
                                    Foreground="#E8EBF0" />
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Build log" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Button Grid.Column="1" Content="Copy" Click="CopySelectedBuildLog_Click" />
                        </Grid>
                        <Border
                            MaxHeight="240"
                            Padding="10"
                            CornerRadius="8"
                            Background="#15171B">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding SelectedBuildLogEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding Text}"
                                                FontFamily="{StaticResource MonospaceFont}"
                                                TextWrapping="Wrap"
                                                Foreground="{Binding Severity, Converter={StaticResource LogSeverityBrush}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
